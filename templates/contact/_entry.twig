{% extends "_layouts/_base.twig" %}

{% block content %}

    <!-- ============================================-->
    <!-- Preloader ==================================-->
    <div class="preloader" id="preloader">
        <div class="loader">
            <div class="line-scale-pulse-out-rapid">
                <div></div>
                <div></div>
                <div></div>
                <div></div>
                <div></div>
            </div>
        </div>
    </div>
    <!-- ============================================-->
    <!-- End of Preloader ===========================-->

    {# Use the same global contact as in the footer #}
    {% set contact = contact ?? null %}
    {% set media = entry.image.one() ?? null %}
    <!-- ============================================-->
    <!-- <section> begin ============================-->
    <section class="py-0" id="page-contact">

        <div class="container-fluid">
            <div class="row">
                <div class="col-lg-6 bg-white mt-5 mt-sm-0 pt-6 pb-6">
                    <div class="row h-100 justify-content-center align-items-start">
                        <div class="col-lg-8" data-zanim-lg='{"animation":"slide-left","delay":0.6}' data-zanim-trigger="scroll">
                            <h1 class="d-inline-block mb-4 mb-lg-6">{{ entry.title }}.</h1>
                            <p class="fw-bold mb-0">
                                {% if contact and contact.name %}{{ contact.name }}{% endif %}
                            </p>
                            <p class="fw-bold mb-0">
                                {% if contact and contact.address %}
                                    {{ contact.address|nl2br }}
                                {% else %}
                                    Bosdreef 10<br/>8210 Veldegem
                                {% endif %}
                            </p>
                            <p class="mb-4">
                                {% if contact and contact.mobile %}
                                    <a class="text-700" href="tel:{{ contact.mobile }}">{{ contact.mobile }}</a>
                                {% endif %}
                                {% if contact and contact.email and contact.mobile %}<br/>{% endif %}
                                {% if contact and contact.email %}
                                    <a class="text-700" href="mailto:{{ contact.email }}">{{ contact.email }}</a>
                                {% endif %}
                            </p>
                            <div class="mt-3">
                                <a class="text-700" href="{{ socials.instagram }}" target="_blank">
                                    <span class="fab fa-instagram hover-text-decoration-none" data-fa-transform="grow-6">&nbsp;&nbsp;</span>
                                    <span class="ms-1">Follow us on Instagram!</span>
                                </a>
                            </div>
                            <div class="mt-5 contact-form">
                                <form id="contact-form" method="post">
                                    {{ csrfInput() }}
                                    {{ actionInput('contact-form/send') }}
                                    
                                    <p id="form-status"></p>
                                    
                                    <div id="dynamic_form">
                                        <div class="width-full width-is-last">
                                            <label for="dynamic_form_firstName" class="required">Naam</label>
                                            <input type="text" id="dynamic_form_firstName" name="fromName" required="required" placeholder="Naam">
                                        </div>
                                        <div class="width-full width-is-last">
                                            <label for="dynamic_form_address">Adres</label>
                                            <input type="text" id="dynamic_form_address" name="message[Adres]" placeholder="Adres">
                                        </div>
                                        <div class="width-one-third width-is-last">
                                            <label for="dynamic_form_zip">Postcode</label>
                                            <input type="text" id="dynamic_form_zip" name="message[Postcode]" placeholder="Postcode">
                                        </div>
                                        <div class="width-full width-is-last">
                                            <label for="dynamic_form_city">Gemeente</label>
                                            <input type="text" id="dynamic_form_city" name="message[Gemeente]" placeholder="Gemeente">
                                        </div>
                                        <div class="width-full width-is-last">
                                            <label for="dynamic_form_phone">Telefoon</label>
                                            <input type="tel" id="dynamic_form_phone" name="message[Telefoon]" placeholder="Telefoon">
                                        </div>
                                        <div class="width-full width-is-last">
                                            <label for="dynamic_form_email" class="required">E-mail</label>
                                            <input type="email" id="dynamic_form_email" name="fromEmail" required="required" placeholder="E-mail">
                                        </div>
                                        <div class="width-full width-is-last">
                                            <label for="dynamic_form_textarea" class="required">Bericht</label>
                                            <textarea id="dynamic_form_textarea" name="message[body]" required="required" placeholder="Schrijf hier je bericht"></textarea>
                                        </div>
                                        <div class="width-full width-is-last">
                                            <div class="d-grid">
                                                <button id="contact-form-submit" type="submit" class="btn btn-block btn-dark mt-4" data-loading-text="Verzenden...">
                                                    <i class="fa fa-paper-plane mr-2"></i> <i class="fa fa-spinner fa-spin d-none mr-2"></i>&nbsp;&nbsp;Bericht versturen
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-lg-6 px-0">
                    <div class="min-vh-100 h-100">
                        {% if media %}
                            <img class="fit-cover h-lg-100 w-100" src="{{ media.getUrl({ format: 'webp', width: 1920 }) }}" alt="{{ media.title }}"/>
                        {% else %}
                            <img class="fit-cover h-lg-100 w-100" src="{{ url('/assets/img/mortex/mortex-01.jpg') }}" alt=""/>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
        <!-- end of .container-->

    </section>
    <!-- <section> close ============================-->
    <!-- ============================================-->

{% endblock %}