<div class="accordion-item">
    <h2 class="accordion-header" id="heading{{ index }}">
        <button class="accordion-button fw-black" type="button" data-bs-toggle="collapse" data-bs-target="#collapse{{ index }}" aria-expanded="false" aria-controls="collapse1">
            {{ faq.title }}
        </button>
    </h2>
    <div class="accordion-collapse collapse {{ index == 1 ? 'show' : ''}}" id="collapse{{ index }}" aria-labelledby="heading{{ index }}" data-bs-parent="#accordionExample">
        <div class="accordion-body custom-text">
            {{ faq.answer|raw }}
        </div>
    </div>
</div>