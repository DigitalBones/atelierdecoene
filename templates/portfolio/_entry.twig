{% extends "_layouts/_base.twig" %}

{% block content %}

    <!-- ============================================-->
    <!-- Preloader ==================================-->
    <div class="preloader" id="preloader">
        <div class="loader">
            <div class="line-scale-pulse-out-rapid">
                <div> </div>
                <div></div>
                <div></div>
                <div></div>
                <div> </div>
            </div>
        </div>
    </div>
    <!-- ============================================-->
    <!-- End of Preloader ===========================-->


    <!-- ============================================-->
    <!-- <section> begin ============================-->
    <section class="mt-5 mt-lg-0 py-lg-7" id="page-portfolio">

        <div class="container">
            <div class="row mb-5 mb-lg-7">
                <div class="col-lg-6">
                    <h1 class="d-inline-block mb-4 mb-lg-4">{{ entry.title }}.</h1>
                    {% if entry.intro %}
                        <p class="">{{ entry.intro }}</p>
                    {% endif %}
                </div>
            </div>

            {% set images = entry.images.all() %}
{#            <ul class="nav font-sans-serif mb-2" data-filter-nav="data-filter-nav">#}
{#                <li class="nav-item"><a class="nav-link isotope-nav active" href="#!" data-filter="*">all</a></li>#}
{#                {% set services = services is defined ? services : craft.entries().section('service').all() %}#}
{#                {% for service in services %}#}
{#                    <li class="nav-item"><a class="nav-link isotope-nav" href="#!" data-filter=".cat-{{ service.id }}">{{ service.title|lower }}</a></li>#}
{#                {% endfor %}#}
{#            </ul>#}
            {% if images %}
                <div class="row g-3 mt-2" id="portfolio-gallery" data-zanim-timeline="{}" data-zanim-trigger="scroll" data-isotope='{"layoutMode":"packery"}' data-filter="*">
                    {% for image in images %}
                        {% set imageServices = image.services.all() ?? [] %}
                        {% set classList = [] %}
                        {% for c in imageServices %}
                            {% set classList = classList|merge(['cat-' ~ c.id]) %}
                        {% endfor %}
                        <div class="col-6 col-md-3 isotope-item {{ classList|join(' ') }}">
                            <a href="#!"
                               data-bp="{{ image.getUrl({ format: 'webp', width: 1920 }) }}"
                               data-bigpicture='{"gallery":"#portfolio-gallery"}'
                               data-caption="{{ image.copyright ?? image.title }}">
                                <img class="w-100 fit-cover"
                                     src="{{ image.getUrl({ format: 'webp', width: 720 }) }}"
                                     alt="{{ image.title }}"
                                     title="{{ image.alt ?? image.title }}"
                                     data-zanim-xs='{"animation":"zoom-in","delay":0.1}' />
                            </a>
                        </div>
                    {% endfor %}
                </div>
            {% endif %}

            {% if entry.cta|length %}
                {% for block in entry.cta %}
                    <div class="col-12 mt-6 pt-6">
                        <div class="row justify-content-center">
                            <div class="col-lg-10 text-center">
                                <h2 class="primary-font fw-bold">{{ block.title }}</h2>
                                <p class="px-lg-6 px-md-5">{{ block.subtitle }}</p>
                                {% if block.button %}
                                    {% include '_includes/_button.twig' with { 'button': block.button } %}
                                {% endif %}
                            </div>
                        </div>
                    </div>
                {% endfor %}
            {% endif %}

        </div>
        <!-- end of .container-->

    </section>
    <!-- <section> close ============================-->
    <!-- ============================================-->

{% endblock %}